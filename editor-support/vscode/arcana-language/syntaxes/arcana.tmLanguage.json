{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Arcana",
  "scopeName": "source.arcana",
  "fileTypes": [
    "arc"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#forewords"
    },
    {
      "include": "#behaviorFunctions"
    },
    {
      "include": "#functionDeclarations"
    },
    {
      "include": "#letBindings"
    },
    {
      "include": "#opaqueDeclarations"
    },
    {
      "include": "#typeDeclarations"
    },
    {
      "include": "#constDeclarations"
    },
    {
      "include": "#langItems"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#memoryPhrases"
    },
    {
      "include": "#qualifiedCalls"
    },
    {
      "include": "#chainStages"
    },
    {
      "include": "#namedEntries"
    },
    {
      "include": "#behaviorStyles"
    },
    {
      "include": "#controlKeywords"
    },
    {
      "include": "#declarationKeywords"
    },
    {
      "include": "#modifierKeywords"
    },
    {
      "include": "#operatorWords"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#lifetimes"
    },
    {
      "include": "#memberAccess"
    },
    {
      "include": "#paths"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.arcana",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.arcana",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.arcana"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.arcana"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.arcana",
              "match": "\\\\(?:[\"\\\\/bfnrt]|u[0-9A-Fa-f]{4})"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.arcana",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "forewords": {
      "patterns": [
        {
          "name": "meta.annotation.arcana",
          "match": "#[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "behaviorFunctions": {
      "patterns": [
        {
          "name": "meta.function.behavior.arcana",
          "match": "\\b(export\\s+)?(behavior|system)(\\[[^\\]]*\\])\\s+(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.arcana"
            },
            "2": {
              "name": "storage.type.arcana"
            },
            "3": {
              "name": "meta.brackets.arcana"
            },
            "4": {
              "name": "storage.type.function.arcana"
            },
            "5": {
              "name": "entity.name.function.arcana"
            }
          }
        }
      ]
    },
    "functionDeclarations": {
      "patterns": [
        {
          "name": "meta.function.arcana",
          "match": "\\b(export\\s+)?(async\\s+)?((?:intrinsic\\s+)?fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.arcana"
            },
            "2": {
              "name": "storage.modifier.arcana"
            },
            "3": {
              "name": "storage.type.function.arcana"
            },
            "4": {
              "name": "entity.name.function.arcana"
            }
          }
        }
      ]
    },
    "letBindings": {
      "patterns": [
        {
          "name": "meta.binding.arcana",
          "match": "\\b(let)\\s+(mut\\s+)?([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.arcana"
            },
            "2": {
              "name": "storage.modifier.arcana"
            },
            "3": {
              "name": "variable.other.definition.arcana"
            }
          }
        },
        {
          "name": "meta.binding.for.arcana",
          "match": "\\b(for)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(in)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.arcana"
            },
            "2": {
              "name": "variable.other.definition.arcana"
            },
            "3": {
              "name": "keyword.control.arcana"
            }
          }
        }
      ]
    },
    "opaqueDeclarations": {
      "patterns": [
        {
          "name": "meta.type.opaque.arcana",
          "match": "\\b(export\\s+)?(opaque\\s+type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.arcana"
            },
            "2": {
              "name": "storage.type.arcana"
            },
            "3": {
              "name": "entity.name.type.arcana"
            }
          }
        }
      ]
    },
    "typeDeclarations": {
      "patterns": [
        {
          "name": "meta.type.arcana",
          "match": "\\b(export\\s+)?(record|obj|enum|trait|create)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.arcana"
            },
            "2": {
              "name": "storage.type.arcana"
            },
            "3": {
              "name": "entity.name.type.arcana"
            }
          }
        }
      ]
    },
    "constDeclarations": {
      "patterns": [
        {
          "name": "meta.const.arcana",
          "match": "\\b(export\\s+)?(const)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.arcana"
            },
            "2": {
              "name": "storage.type.arcana"
            },
            "3": {
              "name": "entity.name.constant.arcana"
            }
          }
        }
      ]
    },
    "langItems": {
      "patterns": [
        {
          "name": "meta.lang-item.arcana",
          "match": "\\b(lang)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
          "captures": {
            "1": {
              "name": "storage.type.arcana"
            },
            "2": {
              "name": "entity.name.constant.arcana"
            },
            "3": {
              "name": "keyword.operator.assignment.arcana"
            }
          }
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.directive.arcana",
          "match": "\\b(import|use|reexport)\\s+([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": {
              "name": "keyword.control.import.arcana"
            },
            "2": {
              "name": "entity.name.namespace.arcana"
            }
          }
        }
      ]
    },
    "memoryPhrases": {
      "patterns": [
        {
          "name": "meta.memory-phrase.arcana",
          "match": "\\b([A-Za-z_][A-Za-z0-9_.]*)\\s*(:)\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(:>)\\s*(?:(?:(?!<:).)*)\\s*(<:)\\s*([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": {
              "name": "support.type.memory.arcana"
            },
            "2": {
              "name": "punctuation.separator.arcana"
            },
            "3": {
              "name": "variable.other.definition.arcana"
            },
            "4": {
              "name": "keyword.operator.arcana"
            },
            "5": {
              "name": "keyword.operator.arcana"
            },
            "6": {
              "name": "entity.name.function.arcana"
            }
          }
        }
      ]
    },
    "qualifiedCalls": {
      "patterns": [
        {
          "name": "meta.qualified-call.arcana",
          "match": "\\b([A-Za-z_][A-Za-z0-9_.]*(?:\\[[^\\]\\n]+\\])?)\\s*(::)\\s*(?:(?:(?!::).)*)\\s*(::)\\s*(call|[A-Za-z_][A-Za-z0-9_.]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.function.arcana"
            },
            "2": {
              "name": "keyword.operator.arcana"
            },
            "3": {
              "name": "keyword.operator.arcana"
            },
            "4": {
              "name": "support.function.qualifier.arcana"
            }
          }
        }
      ]
    },
    "chainStages": {
      "patterns": [
        {
          "name": "meta.chain-stage.arcana",
          "match": "(:=>|:=<|=>|<=)\\s*([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.arcana"
            },
            "2": {
              "name": "support.function.chain-stage.arcana"
            }
          }
        }
      ]
    },
    "namedEntries": {
      "patterns": [
        {
          "name": "meta.named-entry.arcana",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
          "captures": {
            "1": {
              "name": "variable.parameter.arcana"
            },
            "2": {
              "name": "keyword.operator.assignment.arcana"
            }
          }
        }
      ]
    },
    "behaviorStyles": {
      "patterns": [
        {
          "name": "support.function.chain-style.arcana",
          "match": "\\b(forward|lazy|async|parallel|plan|broadcast|collect)\\b(?=\\s*:=)"
        }
      ]
    },
    "controlKeywords": {
      "patterns": [
        {
          "name": "keyword.control.arcana",
          "match": "\\b(if|else|while|for|in|match|return|break|continue|defer)\\b"
        }
      ]
    },
    "declarationKeywords": {
      "patterns": [
        {
          "name": "storage.type.arcana",
          "match": "\\b(export|async|fn|intrinsic|system|record|obj|create|enum|opaque|type|trait|behavior|impl|const|lang|import|use|reexport)\\b"
        }
      ]
    },
    "modifierKeywords": {
      "patterns": [
        {
          "name": "storage.modifier.arcana",
          "match": "\\b(mut|read|edit|take|as|where|with)\\b"
        }
      ]
    },
    "operatorWords": {
      "patterns": [
        {
          "name": "keyword.operator.word.arcana",
          "match": "\\b(and|or|not|weave|split|shr)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.arcana",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.type.builtin.arcana",
          "match": "\\b(Int|Unit|Str|Bool|RangeInt|List|Array|Map|Arena|ArenaId|FrameArena|FrameId|PoolArena|PoolId|Task|Thread|Channel|Mutex|AtomicInt|AtomicBool)\\b"
        },
        {
          "name": "entity.name.type.arcana",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.language.self.arcana",
          "match": "\\bself\\b"
        }
      ]
    },
    "lifetimes": {
      "patterns": [
        {
          "name": "entity.name.label.lifetime.arcana",
          "match": "\\B'[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "memberAccess": {
      "patterns": [
        {
          "name": "variable.other.member.arcana",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "variable.other.member.arcana",
          "match": "(?<=\\.)\\d+"
        }
      ]
    },
    "paths": {
      "patterns": [
        {
          "name": "entity.name.namespace.arcana",
          "match": "\\b(?:[A-Za-z_][A-Za-z0-9_]*\\.)+[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arcana",
          "match": "::|:>|<:|:=>|:=<|=>|<=|->|>>|\\.\\.=|\\.\\.|==|!=|>=|\\+=|-=|\\*=|/=|%=|\\?"
        }
      ]
    }
  }
}
